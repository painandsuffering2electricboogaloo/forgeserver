/*
This file uses the ".json5" file extension which allows for comments like this in a json file!
Your text editor may show this file with invalid/no syntax, if so, we recommend you download:

VSCode: https://code.visualstudio.com/
JSON5 plugin(for VSCode): https://marketplace.visualstudio.com/items?itemName=mrmlnc.vscode-json5

to make editing this file much easier.
*/
{
	// Generates all block states for all blocks in the registry.
	"generate_all_known_states": true,

	"state_swapper": [
		{
        "new": { "Name": "minecraft:barrel" },
        "old": { "Name": "immersiveengineering:crate" }
        }
	],

	/* A map of blocks that specifies what the "old" block is and what its "new" block is.
	   Example:
	   	"swapper": {
	   		"minecraft:coarse_dirt": "minecraft:dirt",
	   		"minecraft:diamond_block": "minecraft:emerald_block"
	   	}
	*/

    // Whether blocks are replaced in existing chunks.
    "retro_gen": true,

    // Swap the block immediately if a player tries to place the "old" version
    "player_placed": false,

    "swapper": {
        "immersiveengineering:ore_lead": "minecraft:stone",
        "immersiveengineering:deepslate_ore_lead": "minecraft:deepslate",
        "tfmg:lead_ore": "minecraft:stone",
        "tfmg:deepslate_lead_ore": "minecraft:deepslate",
        "occultism:silver_ore": "minecraft:stone",
        "occultism:silver_ore_deepslate": "minecraft:deepslate",
        "immersiveengineering:ore_silver": "minecraft:stone",
        "immersiveengineering:deepslate_ore_silver": "minecraft:deepslate",
        "destroy:nickel_ore": "minecraft:stone",
        "destroy:deepslate_nickel_ore": "minecraft:deepslate",
        "immersiveengineering:ore_nickel":"minecraft:stone",
        "immersiveengineering:deepslate_ore_nickel": "minecraft:deepslate",
        "immersiveengineering:ore_uranium": "minecraft:stone",
        "immersiveengineering:deepslate_ore_uranium": "minecraft:deepslate",
        "enlightend_end:irradium_ore": "minecraft:endstone"
    }
}